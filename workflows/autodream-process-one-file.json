              "id": "c1",
              "leftValue": "={{ $json.writeNeeded }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-write",
      "name": "Write Needed?",
