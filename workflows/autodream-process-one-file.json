    {
      "id": "extract-content",
      "name": "Extract Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        0
      ],
      "parameters": {
        "jsCode": "\nconst item = $input.first();\nconst trigger = $('Execute Workflow Trigger').item.json;\nconst fileName = trigger.fileName;\nconst fileId = trigger.fileId;\n\nlet content = '';\nif (item.json && item.json.data) {\n  content = item.json.data;\n} else if (item.json && item.json.body) {\n  content = item.json.body;\n}\n\nconst sys = [\n  'You are a memory consolidation system for Claude Code.',\n  'You receive ONE memory file.',\n  '',\n  'Your tasks:',\n  '1. Consolidate redundant information',\n  '2. Remove outdated or contradictory entries',\n  '3. Improve clarity and precision',\n  '4. Preserve the existing YAML frontmatter format',\n  '',\n  'STRICT rules: Raw JSON ONLY, ZERO backticks. Start with {.',\n  '',\n  'If changed=true: {\"changed\":true,\"content\":\"...\",\"changes\":\"...\",\"observation\":\"...\"}',\n  'If changed=false: {\"changed\":false,\"changes\":\"No changes\",\"observation\":\"...\"}'\n].join('\\n');\n\nconst claudeBody = JSON.stringify({\n  model: 'claude-sonnet-4-6',\n  max_tokens: 4096,\n  system: sys,\n  messages: [{\n    role: 'user',\n    content: 'Run: ' + new Date().toISOString() + '\\nFile: ' + fileName + '\\n\\nContent:\\n' + content.slice(0, 3000)\n  }]\n});\n\nreturn [{ json: { fileName, fileId, fileContent: content, claudeBody } }];\n"
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "anthropicApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.claudeBody }}",
        "options": {}
      },
      "id": "call-claude",
      "name": "Call Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        560,
        0
      ],
      "credentials": {
        "anthropicApi": {
          "id": "YOUR_ANTHROPIC_CREDENTIAL_ID",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const fileName = $('Execute Workflow Trigger').item.json.fileName;\nconst fileId = $('Execute Workflow Trigger').item.json.fileId;\nconst raw = $input.first().json.content[0].text;\nconst cleaned = raw.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/```\\s*$/i, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  return [{ json: { fileName, changed: false, changes: 'Erreur parsing', observation: e.message } }];\n}\n\nreturn [{ json: {\n  fileName,\n  fileId,\n  changed: parsed.changed === true,\n  changes: parsed.changes || 'Aucune modification',\n  observation: parsed.observation || '',\n  newContent: parsed.content || '',\n  writeNeeded: parsed.changed === true && !!parsed.content\n} }];"
      },
      "id": "parse-and-write",
      "name": "Parse and Write",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ]
    },
